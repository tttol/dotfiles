{
  "permissions": {
    "allow": [
      "Edit",
      "Read",
      "Write",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh pr delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh variable delete:*)",
      "Bash(gh label delete:*)",
      "Bash(gh ssh-key delete:*)",
      "Bash(gh gpg-key delete:*)",
      "Bash(gh workflow delete:*)",
      "Bash(gh cache delete:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git revert:*)",
      "Bash(git stash:*)",
      "Bash(git reset:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude has finished task.\" with title \"cc done!\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
